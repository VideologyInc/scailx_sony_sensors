From 32bfd4fb75eb47d4bfe3f4a7b1e6b42543b31667 Mon Sep 17 00:00:00 2001
From: Kobus Goosen <kgoosen@videologyinc.com>
Date: Thu, 5 Jun 2025 19:06:06 +0200
Subject: [PATCH 1/2] install cpython and gsthailo in site-packages

---
 core/hailo/plugins/meson.build  | 11 ++++++++++-
 core/hailo/tracking/meson.build |  2 +-
 2 files changed, 11 insertions(+), 2 deletions(-)

diff --git a/core/hailo/plugins/meson.build b/core/hailo/plugins/meson.build
index 58b2ab3..1ce6945 100644
--- a/core/hailo/plugins/meson.build
+++ b/core/hailo/plugins/meson.build
@@ -123,5 +123,14 @@ python_installation.extension_module('hailo',
     override_options: ['cpp_rtti=true'],
     gnu_symbol_visibility : 'default',
     install: true,
-    install_dir: python_package_install_dir,
+    # install_dir: python_package_install_dir,
+)
+
+# Install the gsthailo Python package
+python_installation.install_sources(
+  [
+    '../python/gsthailo/__init__.py',
+    '../python/gsthailo/video_frame.py'
+  ],
+  subdir: 'gsthailo'
 )
diff --git a/core/hailo/tracking/meson.build b/core/hailo/tracking/meson.build
index 49f1efc..eeaa993 100644
--- a/core/hailo/tracking/meson.build
+++ b/core/hailo/tracking/meson.build
@@ -40,5 +40,5 @@ python_installation.extension_module('pyhailotracker',
     ],
     gnu_symbol_visibility : 'default',
     install: true,
-    install_dir: python_package_install_dir,
+    # install_dir: python_package_install_dir,
 )
\ No newline at end of file

From 45e9c0b98101d0f6d9a816ea5f076b0ec7280296 Mon Sep 17 00:00:00 2001
From: hhdrake <hans.hageman@hotmail.com>
Date: Tue, 13 May 2025 14:29:28 +0200
Subject: [PATCH] Included YUY2 draw_rectangle draw_text draw_line draw_ellipse

---
 core/hailo/plugins/common/hailomat.hpp | 18 ++++++++++++++----
 1 file changed, 14 insertions(+), 4 deletions(-)

diff --git a/core/hailo/plugins/common/hailomat.hpp b/core/hailo/plugins/common/hailomat.hpp
index b4a5417..4c779a5 100644
--- a/core/hailo/plugins/common/hailomat.hpp
+++ b/core/hailo/plugins/common/hailomat.hpp
@@ -287,10 +287,20 @@ public:
         cv::Rect fixed_rect = cv::Rect(rect.x / 2, rect.y, rect.width / 2, rect.height);
         cv::rectangle(m_matrices[0], fixed_rect, get_yuy2_color(color), m_line_thickness);
     }
-    virtual void draw_text(std::string text, cv::Point position, double font_scale, const cv::Scalar color){};
-    virtual void draw_line(cv::Point point1, cv::Point point2, const cv::Scalar color, int thickness, int line_type){};
-    virtual void draw_ellipse(cv::Point center, cv::Size axes, double angle, double start_angle, double end_angle, const cv::Scalar color, int thickness){};
-    virtual void blur(cv::Rect rect, cv::Size ksize){};
+    virtual void draw_text(std::string text, cv::Point position, double font_scale, const cv::Scalar color){
+        cv::putText(m_matrices[0], text, cv::Point(position.x/2, position.y), cv::FONT_HERSHEY_SIMPLEX, font_scale, get_yuy2_color(color), m_font_thickness);
+    };
+    virtual void draw_line(cv::Point point1, cv::Point point2, const cv::Scalar color, int thickness, int line_type){
+        cv::line(m_matrices[0], cv::Point(point1.x / 2, point1.y), cv::Point(point2.x / 2, point2.y), get_yuy2_color(color), thickness, line_type);
+    };
+    virtual void draw_ellipse(cv::Point center, cv::Size axes, double angle, double start_angle, double end_angle, const cv::Scalar color, int thickness){
+        cv::ellipse(m_matrices[0], cv::Point(center.x / 2, center.y), axes, angle, start_angle, end_angle, get_yuy2_color(color), thickness);
+    };
+    virtual void blur(cv::Rect rect, cv::Size ksize){
+        cv::Rect fixed_rect = cv::Rect(rect.x / 2, rect.y, rect.width / 2, rect.height);
+        cv::Mat target_roi = this->m_matrices[0](fixed_rect);
+        cv::blur(target_roi, target_roi, ksize);
+    };
     virtual ~HailoYUY2Mat()
     {
         m_matrices.clear();
